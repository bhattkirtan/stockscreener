"""
Unit Tests - Analysis Skill

Tests indicator calculations and signal generation logic (EVENT-DRIVEN PATTERN).
"""
import pytest
import sys
import os
from datetime import datetime, timezone, timedelta
from unittest.mock import AsyncMock, MagicMock, patch

sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '../..')))

from skills.analysis.analysis_skill import AnalysisSkill
from core.event_bus import Event, EventType, create_candle_closed_event


class TestAnalysisSkill:
    """Test Analysis Skill (Event-Driven Pattern)"""
    
    @pytest.fixture
    def config(self):
        """Analysis configuration"""
        return {
            'supertrend': {'period': 10, 'multiplier': 3.0},
            'sma': {'fast_period': 5, 'slow_period': 20},
            'edge_detection': {
                'enabled': True,
                'lookback_periods': 3,
                'min_body_ratio': 0.6
            }
        }
    
    @pytest.fixture
    def mock_event_bus(self):
        """Mock event bus for testing event publishing"""
        bus = AsyncMock()
        bus.publish = AsyncMock()
        return bus
    
    @pytest.fixture
    def mock_market_data(self):
        """Mock market data skill that provides candle history"""
        market_data = MagicMock()
        # Default: 50 candles with uptrend
        base_time = datetime.now(timezone.utc)
        candles = []
        for i in range(50):
            candle = {
                'timestamp': base_time - timedelta(minutes=250-i*5),
                'open': 1900.00 + i,
                'high': 1905.00 + i,
                'low': 1895.00 + i,
                'close': 1902.00 + i,
                'volume': 1000
            }
            candles.append(candle)
        market_data.get_candle_history.return_value = candles
        return market_data
    
    @pytest.fixture
    def skill(self, config, mock_event_bus, mock_market_data):
        """Analysis skill instance with mocked dependencies"""
        skill = AnalysisSkill(config, event_bus=mock_event_bus, market_data_skill=mock_market_data)
        return skill
    
    def test_initialization(self, skill):
        """Test skill initializes correctly"""
        assert skill.st_period == 10
        assert skill.st_multiplier == 3.0
        assert skill.sma_fast == 5
        assert skill.sma_slow == 20
    
    @pytest.mark.asyncio
    async def test_on_candle_closed_with_insufficient_data(self, skill, mock_event_bus):
        """Test on_candle_closed returns early with insufficient candles"""
        # Override market data to return insufficient candles
        skill.market_data.get_candle_history.return_value = [
            {'timestamp': datetime.now(timezone.utc), 'open': 1950, 'high': 1955, 'low': 1945, 'close': 1952, 'volume': 1000}
        ]
        
        event = create_candle_closed_event(
            instrument='GOLD',
            candle={'timestamp': datetime.now(timezone.utc), 'open': 1950, 'high': 1955, 'low': 1945, 'close': 1952}
        )
        
        await skill.on_candle_closed(event)
        
        # Should NOT publish SIGNAL_GENERATED (insufficient data)
        mock_event_bus.publish.assert_not_called()
    
    @pytest.mark.asyncio
    async def test_on_candle_closed_with_sufficient_data(self, skill, mock_event_bus, mock_market_data):
        """Test on_candle_closed generates signal with sufficient data"""
        event = create_candle_closed_event(
            instrument='GOLD',
            candle={'timestamp': datetime.now(timezone.utc), 'open': 1950, 'high': 1955, 'low': 1945, 'close': 1952}
        )
        
        await skill.on_candle_closed(event)
        
        # Should publish SIGNAL_GENERATED event (or not, depending on if signal generated)
        # Since we have uptrend data, signal should be generated
        if mock_event_bus.publish.called:
            published_event = mock_event_bus.publish.call_args[0][0]
            assert published_event.event_type == EventType.SIGNAL_GENERATED
            assert published_event.instrument == 'GOLD'
            assert published_event.correlation_id == event.correlation_id
    
    @pytest.mark.asyncio
    async def test_edge_detection_prevents_continuous_signals(self, skill, mock_event_bus):
        """Test edge detection only triggers on signal change"""
        event = create_candle_closed_event(
            instrument='GOLD',
            candle={'timestamp': datetime.now(timezone.utc), 'open': 1950, 'high': 1955, 'low': 1945, 'close': 1952}
        )
        
        # First call - may or may not generate signal
        await skill.on_candle_closed(event)
        first_call_count = mock_event_bus.publish.call_count
        
        # Second call with same signal - should NOT generate duplicate
        mock_event_bus.reset_mock()
        await skill.on_candle_closed(event)
        
        # If signal was same, should not publish again
        # This tests edge detection logic
        # (Actual behavior depends on signal state tracking)
    
    @pytest.mark.asyncio
    async def test_signal_storage_in_event_payload(self, skill, mock_event_bus):
        """Test signal and indicators are stored in event payload"""
        event = create_candle_closed_event(
            instrument='GOLD',
            candle={'timestamp': datetime.now(timezone.utc), 'open': 1950, 'high': 1955, 'low': 1945, 'close': 1952}
        )
            'timestamp': datetime.now(timezone.utc),
            'open': 1950.00,
            'high': 1952.00,
            'low': 1945.00,
            'close': 1946.00,  # Small body, might be edge
            'volume': 1000
        }
        context_with_candles.candles.append(reversal_candle)
        
        signal = skill.analyze(context_with_candles)
