# ============================================================================
# Environment Variables for Capital.com Trading Cloud Function
# ============================================================================
#
# IMPORTANT: This file is for LOCAL DEVELOPMENT ONLY
# For production deployment, use Google Cloud Secret Manager
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in the .env file
# 3. Never commit .env to version control
#
# ============================================================================

# API Credentials (JSON format)
# This contains all authentication credentials for Capital.com API
#
# Required fields:
# - apikey: Your TradingView or webhook API key
# - username: Capital.com account username/email
# - password: Capital.com account password
# - capkey: Capital.com API key (get from Capital.com developer portal)
#
# Example format:
# apicredentials={"apikey":"tv_abc123xyz","username":"trader@example.com","password":"SecurePass123!","capkey":"cap_key_abc123xyz"}

apicredentials=

# ============================================================================
# Additional Configuration (optional)
# ============================================================================

# Enable debug logging (true/false)
# DEBUG=false

# Custom Firestore project ID (defaults to current GCP project)
# FIRESTORE_PROJECT_ID=

# ============================================================================
# Production Deployment Note
# ============================================================================
#
# For production, create a secret in Google Cloud Secret Manager:
#
# echo '{"apikey":"xxx","username":"xxx","password":"xxx","capkey":"xxx"}' | \
#   gcloud secrets create capitalService --data-file=-
#
# Then reference it in your Cloud Function deployment:
#   --set-secrets "apicredentials=capitalService:latest"
#
# ============================================================================

