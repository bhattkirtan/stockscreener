FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Only the dependencies the scheduler actually needs
COPY requirements-data-updater.txt ./
RUN pip install --no-cache-dir -r requirements-data-updater.txt

COPY . .

RUN useradd -m appuser && mkdir -p /data && chown -R appuser:appuser /app /data
USER appuser

CMD ["python", "-m", "src.services.data_update_scheduler", "--mode", "production"]
