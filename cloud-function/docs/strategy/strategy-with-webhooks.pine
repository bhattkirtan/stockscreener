//@version=6
indicator("Supertrend, BB, VWAP with Fib TP - Enhanced with Webhooks", overlay=true)

// ════════════════════════════════════════════════════════════════════════════
// INPUTS - General Settings
// ════════════════════════════════════════════════════════════════════════════
use_st      = input(true, title="Use Super Trend (MA)", group="Indicators")
use_bb      = input(false, title="Use Bollinger Bands (BB)", group="Indicators")
use_vwap    = input(true, title="Use VWAP", group="Indicators")
splitTp     = input(true, title="Use Multiple TP", group="Trade Management")
useStopLoss = input(true, title="Use Stoploss", group="Trade Management")

// API Settings
api_key    = input.string("IuMfu0djI6ocgxgcbbQEdg", title="API Key", group="API")
order_size = input.int(200, title="Total Order Size", group="API")

// Time Filter (only trade between startHour and endHour)
startHour   = input.int(3, title="Start Hour", group="Time Filter")
endHour     = input.int(22, title="End Hour", group="Time Filter")
inTradeTime = (hour >= startHour and hour < endHour)

// Trade Settings
stoplossCorrection = input.float(0.6, title="Stoploss Factor", step=0.01, group="Trade Management", tooltip="SL distance as % of TP distance")

// Price Type
price_type = input.string("close", title="Price Type", options=["close", "hlc3"], group="Indicators")
get_price(type) =>
    switch type
        "close" => close
        "hlc3"  => hlc3
price = get_price(price_type)

// ════════════════════════════════════════════════════════════════════════════
// VWAP Settings
// ════════════════════════════════════════════════════════════════════════════
sho_tf3 = input.bool(true, "Show", inline="D", group="VWAP")
src_tf3 = input.source(hlc3, "", inline="D", group="VWAP")
res_tf3 = input.timeframe("D", "", inline="D", group="VWAP")
wid_tf3 = input.int(2, "", minval=0, inline="D", group="VWAP")
col_tf3 = input.color(color.red, "", inline="D", group="VWAP")

// ════════════════════════════════════════════════════════════════════════════
// TP and Stop Loss Settings
// ════════════════════════════════════════════════════════════════════════════
hist_bars    = input.int(50, title="Historical Bars for Support/Resistance", group="Support & Resistance")
hist_barsSL  = input.int(5,  title="Historical Bars for S/R for Stop Loss", group="Support & Resistance")
fib_level_perc1 = input.float(0.7, title="FB 1 Multiplier", step=0.05, group="Take Profit")
fib_level_perc2 = input.float(0.8, title="FB 2 Multiplier", step=0.05, group="Take Profit")
fib_level_perc3 = input.float(0.9, title="FB 3 Multiplier", step=0.05, group="Take Profit")

// ════════════════════════════════════════════════════════════════════════════
// Supertrend Settings
// ════════════════════════════════════════════════════════════════════════════
factor     = input(3.0, title="ATR Factor", group="Supertrend")
atr_period = input(21, title="ATR Period", group="Supertrend")
[supertrend, direction] = ta.supertrend(factor, atr_period)
directionOfTrend = ta.change(direction)

// ════════════════════════════════════════════════════════════════════════════
// Bollinger Bands Settings
// ════════════════════════════════════════════════════════════════════════════
bb_length = input.int(20, title="BB Length", group="Bollinger Bands")
bb_mult   = input.float(1.0, title="BB Multiplier", group="Bollinger Bands")
basis     = ta.sma(price, bb_length)
upper_bb  = basis + bb_mult * ta.stdev(price, bb_length)
lower_bb  = basis - bb_mult * ta.stdev(price, bb_length)
plot(use_bb ? upper_bb : na, title="Upper BB", color=color.green)
plot(use_bb ? lower_bb : na, title="Lower BB", color=color.red)

// ════════════════════════════════════════════════════════════════════════════
// VWAP Calculation
// ════════════════════════════════════════════════════════════════════════════
shoTF(res) => timeframe.in_seconds(timeframe.period) < timeframe.in_seconds(res)
vwaptf3 = sho_tf3 and shoTF(res_tf3) ? ta.vwap(src_tf3, timeframe.change(res_tf3)) : na
plot(vwaptf3, "VWAP", col_tf3, math.max(1, wid_tf3))

// Plot Supertrend
plot(supertrend, title="Supertrend", color=(direction < 0 ? color.red : color.green))

// ════════════════════════════════════════════════════════════════════════════
// SUPPORT & RESISTANCE
// ════════════════════════════════════════════════════════════════════════════
var float resistance   = na
var float support      = na
var float resistanceSL = na
var float supportSL    = na

swingHigh   = ta.highest(high, hist_bars)
swingLow    = ta.lowest(low,  hist_bars)
swingHighSL = ta.highest(high, hist_barsSL)
swingLowSL  = ta.lowest(low,  hist_barsSL)

if high == swingHigh
    resistance   := high
    resistanceSL := swingHighSL
if low == swingLow
    support   := low
    supportSL := swingLowSL

// ════════════════════════════════════════════════════════════════════════════
// FIBONACCI LEVELS & POSITION SIZING
// ════════════════════════════════════════════════════════════════════════════
var float fibLevel1 = na
var float fibLevel2 = na
var float fibLevel3 = na
var float stopLevel = na
var float fibRange  = na
var float entry_price = na

// Order sizing allocation for TP levels (matching backend expectations)
var float order_size1 = order_size * 0.5  // 50% at TP1
var float order_size2 = order_size * 0.3  // 30% at TP2
var float order_size3 = order_size * 0.2  // 20% at TP3

// ════════════════════════════════════════════════════════════════════════════
// SIGNAL FLAGS
// ════════════════════════════════════════════════════════════════════════════
var bool longSignal  = false
var bool shortSignal = false
var bool longOrder   = false
var bool shortOrder  = false

// ════════════════════════════════════════════════════════════════════════════
// ENTRY CONDITIONS
// ════════════════════════════════════════════════════════════════════════════
longCondition = inTradeTime and barstate.isconfirmed and 
 (not use_st or use_st and directionOfTrend < 0) and 
 (not use_bb or use_bb and close < upper_bb) and 
 (not use_vwap or use_vwap and price > vwaptf3)

shortCondition = inTradeTime and barstate.isconfirmed and 
 (not use_st or use_st and directionOfTrend > 0) and 
 (not use_bb or use_bb and close > lower_bb) and 
 (not use_vwap or use_vwap and price < vwaptf3)

// ════════════════════════════════════════════════════════════════════════════
// ENTRY LOGIC WITH WEBHOOK ALERTS
// ════════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed
    // ──── Long Entry ────
    if longCondition and not na(support)
        longSignal  := true
        longOrder   := true
        shortOrder  := false
        entry_price := close
        fibRange    := price - support
        fibLevel1   := price + fibRange * fib_level_perc1
        fibLevel2   := price + fibRange * fib_level_perc2
        fibLevel3   := price + fibRange * fib_level_perc3
        
        // Calculate TP1 distance and stop loss as percentage
        tp1 = fibLevel1 - price
        sl = price - (tp1 * stoplossCorrection)
        stopLevel := sl
        
        // Webhook alert for LONG entry (matching backend API format)
        jsonLong = '{"key": "' + api_key + '", "action": "entry", "epic": "' + syminfo.ticker + 
         '", "direction": "BUY", "stopLevel": ' + str.tostring(stopLevel) + 
         ', "fibLevel1": ' + str.tostring(fibLevel1) + 
         ', "fibLevel2": ' + str.tostring(fibLevel2) + 
         ', "fibLevel3": ' + str.tostring(fibLevel3) + 
         ', "size1": ' + str.tostring(order_size1) + 
         ', "size2": ' + str.tostring(order_size2) + 
         ', "size3": ' + str.tostring(order_size3) + 
         ', "inTradeTime": true}'
        alert(jsonLong, alert.freq_once_per_bar_close)
    
    // ──── Short Entry ────
    if shortCondition and not na(resistance)
        shortSignal := true
        shortOrder  := true
        longOrder   := false
        entry_price := close
        fibRange    := resistance - price
        fibLevel1   := price - fibRange * fib_level_perc1
        fibLevel2   := price - fibRange * fib_level_perc2
        fibLevel3   := price - fibRange * fib_level_perc3
        
        // Calculate TP1 distance and stop loss
        tp1 = price - fibLevel1
        sl = price + (tp1 * stoplossCorrection)
        stopLevel := sl
        
        // Webhook alert for SHORT entry (matching backend API format)
        jsonShort = '{"key": "' + api_key + '", "action": "entry", "epic": "' + syminfo.ticker + 
         '", "direction": "SELL", "stopLevel": ' + str.tostring(stopLevel) + 
         ', "fibLevel1": ' + str.tostring(fibLevel1) + 
         ', "fibLevel2": ' + str.tostring(fibLevel2) + 
         ', "fibLevel3": ' + str.tostring(fibLevel3) + 
         ', "size1": ' + str.tostring(order_size1) + 
         ', "size2": ' + str.tostring(order_size2) + 
         ', "size3": ' + str.tostring(order_size3) + 
         ', "inTradeTime": true}'
        alert(jsonShort, alert.freq_once_per_bar_close)

// ════════════════════════════════════════════════════════════════════════════
// EXIT / UPDATE LOGIC
// ════════════════════════════════════════════════════════════════════════════
original_close = request.security(syminfo.tickerid, timeframe.period, close)

// Helper function to send update-sl webhook
update_stop_loss(level) =>
    json = '{"key": "' + api_key + '", "action": "update-sl", "epic": "' + syminfo.ticker + 
     '", "stopLevel": ' + str.tostring(level) + ', "inTradeTime": true}'
    alert(json, alert.freq_once_per_bar_close)
    level

// Helper function to send exit webhook
send_exit_alert() =>
    json = '{"key": "' + api_key + '", "action": "exit", "epic": "' + syminfo.ticker + 
     '", "inTradeTime": true}'
    alert(json, alert.freq_once_per_bar_close)

// ──── Stop Loss Hit ────
if not na(stopLevel) and useStopLoss and 
 ((longOrder and (original_close < stopLevel)) or (shortOrder and (original_close > stopLevel)))
    send_exit_alert()
    label.new(bar_index, stopLevel, "SL Hit", color=color.black, style=label.style_cross, size=size.tiny)
    longOrder  := false
    shortOrder := false
    fibLevel1  := na
    fibLevel2  := na
    fibLevel3  := na
    stopLevel  := na

// ──── Take Profit 1 (50% exit, move SL to entry) ────
if splitTp and not na(fibLevel1) and 
 ((longOrder and (original_close > fibLevel1)) or (shortOrder and (original_close < fibLevel1)))
    stopLevel := update_stop_loss(entry_price)
    entry_price := fibLevel1    
    label.new(bar_index, fibLevel1, "TP1 Hit (50%)", color=color.yellow, style=label.style_cross, size=size.tiny)
    fibLevel1 := na

// ──── Take Profit 2 (30% exit, move SL to TP1) ────
if splitTp and not na(fibLevel2) and 
 ((longOrder and (original_close > fibLevel2)) or (shortOrder and (original_close < fibLevel2)))
    stopLevel := update_stop_loss(entry_price)
    entry_price := fibLevel2
    label.new(bar_index, fibLevel2, "TP2 Hit (30%)", color=color.yellow, style=label.style_cross, size=size.tiny)
    fibLevel2 := na

// ──── Take Profit 3 (20% final exit) ────
if splitTp and not na(fibLevel3) and 
 ((longOrder and (original_close > fibLevel3)) or (shortOrder and (original_close < fibLevel3)))
    send_exit_alert()
    label.new(bar_index, fibLevel3, "TP3 Hit (20%)", color=color.yellow, style=label.style_cross, size=size.tiny)
    fibLevel3 := na
    stopLevel := na
    longOrder  := false
    shortOrder := false

// ──── Single TP (if splitTp disabled) ────
if not splitTp and not na(fibLevel1) and 
 ((longOrder and (original_close > fibLevel1)) or (shortOrder and (original_close < fibLevel1)))
    send_exit_alert()
    label.new(bar_index, fibLevel1, "TP Hit (100%)", color=color.yellow, style=label.style_triangledown, size=size.tiny)
    fibLevel1 := na
    fibLevel2 := na
    fibLevel3 := na
    stopLevel  := na
    longOrder  := false
    shortOrder := false

// ════════════════════════════════════════════════════════════════════════════
// PLOT GLOBAL BUY/SELL SIGNALS
// ════════════════════════════════════════════════════════════════════════════
plotshape(longCondition, style=shape.labelup, location=location.belowbar, 
 color=color.new(#046ff9, 0), size=size.tiny, text="Buy", textcolor=color.white)
plotshape(shortCondition, style=shape.labeldown, location=location.abovebar, 
 color=color.new(#046ff9, 0), size=size.tiny, text="Sell", textcolor=color.white)
