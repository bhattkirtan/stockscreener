rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Trading signals collection
    match /trading_signals/{signalId} {
      // Allow bot to write signals (server-side with service account)
      allow write: if true;
      
      // Allow anyone to read signals (for testing)
      // TODO: Change to 'if request.auth != null' for production
      allow read: if true;
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
